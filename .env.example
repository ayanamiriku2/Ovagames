# Mirror domain (your domain)
MIRROR_DOMAIN=ovagames.onl

# Source/origin domain to mirror
SOURCE_DOMAIN=www.ovagames.com

# Port to listen on
PORT=3000

# Protocol for mirror (http or https)
MIRROR_PROTOCOL=https

# Source protocol
SOURCE_PROTOCOL=https

# Optional: Custom User-Agent
# USER_AGENT=Mozilla/5.0 (compatible; MirrorBot/1.0)
